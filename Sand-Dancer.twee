  (set: ($itemsAt)'s _loc to it + (a: _item))
  (set: $locOf to it + (dm: _item, _loc))
  (replace:?you-can-also-see)[($youCanAlsoSeeContents:)]
  ($updateInventory:)
  (out-data:'')
]))\
